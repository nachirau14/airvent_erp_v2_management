# ─── FabriFlow ERP Secrets ─────────────────────────────────────────
# Paste this into Streamlit Community Cloud → App Settings → Secrets
# Replace all placeholder values with your real credentials
# ──────────────────────────────────────────────────────────────────

[aws]
AWS_ACCESS_KEY_ID = "AKIA..."
AWS_SECRET_ACCESS_KEY = "wJalr..."
